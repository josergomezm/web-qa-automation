+import { AutomationService } from './services/automation';
+
+async function run() {
+    console.log('Initializing AutomationService...');
+    const service = new AutomationService();
+    await service.initialize();
+
+    // Test case: Wait for h1 with text 'Example Domain' on example.com
+    // Using complex locator: locator('h1').filter({ hasText: 'Example Domain' })
+    const steps = [
+        { action: 'navigate', url: 'https://example.com' },
+        {
+            action: 'wait',
+            waitForCondition: {
+                type: 'visible',
+                selector: "locator('h1').filter({ hasText: 'Example Domain' })",
+                timeout: 10000
+            }
+        }
+    ];
+
+    try {
+        console.log('Starting execution...');
+        const result = await service.executeSteps(steps, undefined, async (msg) => console.log(msg));
+
+        const failed = result.steps.some((s: any) => !s.success);
+        if (failed) {
+            console.error('FAILURE: Some steps failed');
+            console.log(JSON.stringify(result.steps, null, 2));
+            process.exit(1);
+        } else {
+            console.log('SUCCESS: All steps passed');
+            process.exit(0);
+        }
+
+    } catch (err) {
+        console.error('Execution threw error:', err);
+        process.exit(1);
+    }
+}
+
+run();
